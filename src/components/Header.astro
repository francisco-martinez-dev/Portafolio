---
import ThemeToggle from './react/ThemeToggle.jsx';
import { Github, Linkedin, Mail } from 'lucide-astro';

const navLinks = [
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#experiencia', label: 'Experiencia' },
  { href: '#skills', label: 'Skills' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 border-b border-line-light/70 bg-paper/80 backdrop-blur dark:border-line-dark/70 dark:bg-ink/80">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="#top" class="font-display text-lg font-semibold tracking-tight">
      Francisco Martínez
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Navegación principal">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm text-steel transition-colors hover:text-accent dark:text-line-light">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="https://www.linkedin.com/in/francisco-alejandro-martinez-linares/" target="_blank" rel="noreferrer" aria-label="LinkedIn" class="text-steel transition-colors hover:text-accent dark:text-line-light">
        <Linkedin size={18} strokeWidth={1.75} />
      </a>
      <a href="https://github.com/francisco-martinez-dev" target="_blank" rel="noreferrer" aria-label="GitHub" class="text-steel transition-colors hover:text-accent dark:text-line-light">
        <Github size={18} strokeWidth={1.75} />
      </a>
      <a href="mailto:franciscolinares000@gmail.com" aria-label="Enviar correo" class="text-steel transition-colors hover:text-accent dark:text-line-light">
        <Mail size={18} strokeWidth={1.75} />
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>