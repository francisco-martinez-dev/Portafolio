---
export interface Props {
  name: string;
  problem: string;
  decision: string;
  result: string;
  stack: string[];
  demoUrl: string;
  repoUrl: string;
  image?: string;
  index: number;
}

const { name, problem, decision, result, stack, demoUrl, repoUrl, image, index } = Astro.props;
---

<article class="reveal grid gap-8 border-b border-line-light py-12 last:border-b-0 dark:border-line-dark md:grid-cols-2 md:gap-10">
  <div>
    <p class="font-display text-xs uppercase tracking-[0.2em] text-accent">
      Proyecto {String(index).padStart(2, '0')}
    </p>
    <h3 class="mt-2 font-display text-2xl font-semibold tracking-tight">{name}</h3>

    <dl class="mt-5 space-y-3 text-sm">
      <div>
        <dt class="text-steel dark:text-line-light">Problema</dt>
        <dd class="mt-0.5">{problem}</dd>
      </div>
      <div>
        <dt class="text-steel dark:text-line-light">Decisión técnica</dt>
        <dd class="mt-0.5">{decision}</dd>
      </div>
      <div>
        <dt class="text-steel dark:text-line-light">Resultado</dt>
        <dd class="mt-0.5">{result}</dd>
      </div>
    </dl>

    <div class="mt-5 flex flex-wrap gap-2">
      {stack.map((tech) => (
        <span class="rounded-full border border-line-light px-3 py-1 text-xs text-steel dark:border-line-dark dark:text-line-light">
          {tech}
        </span>
      ))}
    </div>

    <div class="mt-6 flex gap-4">
      <a href={demoUrl} target="_blank" rel="noreferrer" class="rounded-full bg-ink px-5 py-2.5 text-sm font-medium text-paper transition-transform duration-200 hover:-translate-y-0.5 dark:bg-accent dark:text-ink">
        Demo
      </a>
      <a href={repoUrl} target="_blank" rel="noreferrer" class="rounded-full border border-line-light px-5 py-2.5 text-sm font-medium transition-colors duration-200 hover:border-accent hover:text-accent dark:border-line-dark">
        Código
      </a>
    </div>
  </div>

  <div class="flex items-center">
    <slot>
      {image && (
        <img
          src={image}
          alt={`Captura de pantalla del proyecto ${name}`}
          loading="lazy"
          class="w-full rounded-xl border border-line-light dark:border-line-dark"
        />
      )}
    </slot>
  </div>
</article>